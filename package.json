{
  "name": "openharness",
  "private": true,
  "license": "UNLICENSED",
  "version": "1.0.0-alpha.update.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:server",
    "build:server": "node scripts/build-server.mjs",
    "lint": "eslint .",
    "test:auto-router-trace-ui": "tsx scripts/test-auto-router-trace-ui.ts",
    "test:auto-router-context": "tsx scripts/test-auto-router-context.ts",
    "test:router-learning-debug-loop": "tsx scripts/test-router-learning-debug-loop.ts",
    "test:router-learning-export": "tsx scripts/test-router-learning-export.ts",
    "test:personalization-store": "tsx scripts/test-personalization-store.ts",
    "test:release-notes": "tsx scripts/test-release-notes.ts",
    "test:crash-reports": "tsx scripts/test-crash-reports.ts",
    "test:capability-settings": "tsx scripts/test-capability-settings.ts",
    "test:system-theme-default": "tsx scripts/test-system-theme-default.ts",
    "test:router-learning-import": "tsx scripts/test-router-learning-import.ts",
    "test:router-learning-outcomes": "tsx scripts/test-router-learning-outcome-persistence.ts",
    "test:tool-reliability": "tsx scripts/test-tool-reliability.ts",
