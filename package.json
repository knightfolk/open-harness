      "dist/**",
      "dist-server/**",
      "electron/**",
      "CHANGELOG.md",
      "package.json",
      "package-lock.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "knightfolk",
        "repo": "open-harness"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "notarize": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "OpenHarness-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "OpenHarness-${version}-windows-${arch}.${ext}"
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "artifactName": "OpenHarness-${version}-linux-${arch}.${ext}"
    }
  }
