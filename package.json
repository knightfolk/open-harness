    "test:theme-contrast": "tsx scripts/test-theme-contrast.ts",
    "test:theme-reduced-transparency": "tsx scripts/test-theme-reduced-transparency.ts",
    "test:theme-reduced-motion": "tsx scripts/test-theme-reduced-motion.ts",
    "test:theme-accessibility": "npm run test:theme-contrast && npm run test:theme-reduced-transparency && npm run test:theme-reduced-motion",
    "test:premier-narrow-layout": "tsx scripts/test-premier-narrow-layout.ts",
    "test:premier-proof-trust": "tsx scripts/test-premier-proof-trust.ts",
    "test:premier-steering-contract": "tsx scripts/test-premier-steering-contract.ts",
    "test:premier-artifact-review": "tsx scripts/test-premier-artifact-review.ts",
    "test:premier-calm-chat": "tsx scripts/test-premier-calm-chat.ts",
    "test:premier-active-work": "tsx scripts/test-premier-active-work.ts",
    "test:premier-layout-shell": "tsx scripts/test-premier-layout-shell.ts",
    "test:premier-agent-detail": "tsx scripts/test-premier-agent-detail.ts",
    "test:premier-model-harness": "tsx scripts/test-premier-model-harness.ts",
    "test:model-metadata-refresh": "tsx scripts/test-model-metadata-refresh.ts",
    "test:premier-theme-textures": "tsx scripts/test-premier-theme-textures.ts",
    "test:premier-review-changes": "tsx scripts/test-premier-review-changes.ts",
    "test:premier-baseline-manifest": "tsx scripts/test-premier-baseline-manifest.ts",
    "test:premier-stop-condition-audit": "tsx scripts/test-premier-stop-condition-audit.ts",
    "test:premier-prompt-source-provenance": "tsx scripts/test-premier-prompt-source-provenance.ts",
    "test:premier-live-evidence-guard": "tsx scripts/test-premier-live-evidence-guard.ts",
    "test:premier-approval-boundaries": "tsx scripts/test-premier-approval-boundaries.ts",
    "test:premier-closeout-matrix": "tsx scripts/test-premier-closeout-matrix.ts",
    "test:premier-restart-scope": "tsx scripts/test-premier-restart-scope.ts",
    "test:premier-worktree-isolation": "tsx scripts/test-premier-worktree-isolation.ts",
    "test:post-alpha-followups": "tsx scripts/test-post-alpha-followups.ts",
    "test:premier-no-spend": "npm run test:theme-accessibility && npm run test:prompt-routing-memory && npm run test:execute-proof-hygiene && npm run test:premier-narrow-layout && npm run test:premier-proof-trust && npm run test:premier-steering-contract && npm run test:premier-artifact-review && npm run test:premier-calm-chat && npm run test:premier-active-work && npm run test:premier-layout-shell && npm run test:premier-agent-detail && npm run test:premier-model-harness && npm run test:premier-theme-textures && npm run test:premier-review-changes && npm run test:premier-baseline-manifest && npm run test:premier-stop-condition-audit && npm run test:premier-prompt-source-provenance && npm run test:premier-live-evidence-guard && npm run test:premier-approval-boundaries && npm run test:premier-closeout-matrix && npm run test:premier-restart-scope && npm run test:premier-worktree-isolation && npm run check:premier-closeout-readiness",
    "check:premier-no-spend": "npm run test:premier-no-spend && npm run lint && npm run build",
    "test:side-chat-main-session-isolation": "tsx scripts/test-side-chat-main-session-isolation.ts",
    "test:routing-adherence": "tsx scripts/test-routing-adherence.ts",
    "test:prompt-routing-output-p0": "tsx scripts/test-prompt-routing-output-p0.ts",
    "test:prompt-routing-quality-readiness": "tsx scripts/test-prompt-routing-quality-readiness.ts",
    "test:prompt-strategy-database": "tsx scripts/test-prompt-strategy-database.ts",
    "test:prompt-routing-memory": "npm run test:prompt-routing-quality-readiness && npm run test:prompt-routing-output-p0 && npm run test:routing-adherence && npm run test:prompt-strategy-database && npm run test:router-learning-outcomes && npm run test:tool-reliability && npm run test:tool-reliability-cache && npm run test:router-learning-export && npm run test:router-learning-import && npm run test:auto-router-context",
    "test:prompt-routing-roguelike-planning": "tsx scripts/test-prompt-routing-roguelike-planning.ts",
    "test:harness-task-seeding": "tsx scripts/test-harness-task-seeding.ts",
    "test:execute-proof-hygiene": "tsx scripts/test-execute-proof-hygiene.ts",
    "test:neon-decade-descent": "tsx scripts/test-neon-decade-descent.ts",
    "test:ship-readiness": "tsx scripts/test-ship-readiness.ts",
    "ship:check": "tsx scripts/run-ship-readiness.ts",
    "smoke:standalone-game-browser": "node scripts/smoke-standalone-game-browser.mjs",
    "ship:check:neon-decade": "npm run test:neon-decade-descent -- ${OPENHARNESS_NEON_DECADE_DIR:-../neon-decade-descent} && tsx scripts/run-ship-readiness.ts ${OPENHARNESS_NEON_DECADE_DIR:-../neon-decade-descent} && npm run smoke:standalone-game-browser -- ${OPENHARNESS_NEON_DECADE_DIR:-../neon-decade-descent}",
    "automation:model-ranking-token-spend": "tsx scripts/run-model-ranking-token-spend-automation.ts",
    "test:planning-room-failure-hygiene": "tsx scripts/test-planning-room-failure-hygiene.ts",
    "test:session-persistence": "tsx scripts/test-session-persistence-regression.ts",
    "test:sse-progress": "tsx scripts/test-sse-progress-regression.ts",
    "test:hardening": "tsx scripts/test-tool-policy.ts && tsx scripts/test-security-remediations.ts && tsx scripts/test-auto-router-context.ts && tsx scripts/test-router-learning-export.ts && tsx scripts/test-router-learning-import.ts && npm run test:theme-accessibility && tsx scripts/test-redaction.ts && tsx scripts/test-session-redaction.ts && tsx scripts/test-artifact-redaction.ts && tsx scripts/test-process-ledger-redaction.ts && tsx scripts/test-mcp-redaction.ts && tsx scripts/test-prompt-injection-boundaries.ts && tsx scripts/test-command-safety.ts",
    "test:auto-update-packaging": "tsx scripts/test-auto-update-packaging.ts",
    "smoke:tool-boundaries": "node scripts/smoke-tool-boundaries.mjs",
    "smoke:browser-deep": "node scripts/smoke-browser-deep.mjs",
    "smoke:docker-ui": "node scripts/smoke-docker-ui.mjs",
    "smoke:ui-clicks": "node scripts/smoke-ui-clicks.mjs",
    "preview": "vite preview",
    "smoke:minimax": "node scripts/smoke-minimax.mjs",
    "test:webbridge-runtime-regression": "tsx scripts/test-webbridge-runtime-regression.ts",
    "server": "dotenv -- tsx server/index.ts",
    "dev:all": "node scripts/start.mjs",
    "electron": "electron .",
    "start": "node scripts/start.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --arm64 --x64",
    "dist:mac:notarized": "npm run notarize:check && npm run dist:mac && npm run notarize:verify",
    "dist:mac:notarized:local": "APPLE_KEYCHAIN_PROFILE=openharness-notary npm run dist:mac:notarized",
    "dist:win": "npm run build && electron-builder --win nsis zip --x64 --arm64",
    "dist:linux": "npm run build && electron-builder --linux AppImage tar.gz --x64 --arm64",
    "dist:all": "npm run build && electron-builder --mac dmg zip --win nsis zip --linux AppImage tar.gz --arm64 --x64",
    "notarize:check": "node scripts/check-notarization-env.mjs",
    "notarize:verify": "node scripts/verify-macos-notarization.mjs",
    "electron:prod": "npm run build && electron .",
    "check:live-tool-error-evidence": "tsx scripts/check-live-tool-error-evidence.ts",
    "run:live-tool-error-recovery": "tsx scripts/run-live-tool-error-recovery-scenario.ts",
    "check:premier-closeout-readiness": "tsx scripts/check-premier-closeout-readiness.ts"
  },
  "dependencies": {
    "allotment": "^1.20.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.openharness.desktop",
    "productName": "OpenHarness",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-server/**",
      "electron/**",
      "CHANGELOG.md",
      "package.json",
      "package-lock.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "knightfolk",
        "repo": "open-harness"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "notarize": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "OpenHarness-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "OpenHarness-${version}-windows-${arch}.${ext}"
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "artifactName": "OpenHarness-${version}-linux-${arch}.${ext}"
    }
  }
}
